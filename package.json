{
  "name": "archive-loader",
  "version": "1.0.0",
  "description": "Web server and client application used to load and manage the metadata used by the PDS Registry and Web UI services",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "build:frontend": "vite build",
    "dev:frontend": "vite",
    "mongo-dev": "mongod --dbpath=data",
    "solr-dev": "docker run -p 8983:8983 solr:7 -DzkRun",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "author": "Mike Drum mdrum@psi.edu",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.888.0",
    "assert": "^1.5.1",
    "bcrypt": "^6.0.0",
    "connect-mongo": "^3.2.0",
    "express": "^4.18.2",
    "express-session": "^1.19.0",
    "fast-xml-parser": "^5.5.8",
    "got": "^11.8.6",
    "helmet": "^3.23.3",
    "mongodb": "^3.6.6",
    "multer": "^2.0.2",
    "passport": "^0.6.0",
    "passport-local": "^1.0.0",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@playwright/test": "^1.58.2",
    "@tanstack/react-query": "^5.90.21",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@tiptap/extension-image": "^3.7.2",
    "@tiptap/extension-link": "^3.7.2",
    "@tiptap/extension-underline": "^3.7.2",
    "@tiptap/react": "^3.7.2",
    "@tiptap/starter-kit": "^3.7.2",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv": "^8.6.0",
    "jsdom": "^28.1.0",
    "msw": "^2.12.10",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^7.13.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
